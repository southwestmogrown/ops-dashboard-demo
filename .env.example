# Override the per-shift RNG seed for a consistent, deterministic data run.
#
# Recommended production value: 7957
#   VS1 Line 1 runs clean (~98% FPY), four remaining lines are at-risk
#   with high changeover counts — exercises every status colour in the UI.
#
# Omit to use shift defaults (day=1001, night=3003).
# Set in Vercel: Project → Settings → Environment Variables → DEMO_SEED
DEMO_SEED=7957
