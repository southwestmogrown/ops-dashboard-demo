# ── Turso database (libSQL) ───────────────────────────────────────────────────
# Local dev: uses a local SQLite file (no auth token needed).
# Production (Vercel): connect Turso via the Vercel Marketplace, then copy the
#   injected values here or set them in Project > Settings > Environment Variables.
TURSO_DATABASE_URL=file:local.db
TURSO_AUTH_TOKEN=

# ── Demo / app config ─────────────────────────────────────────────────────────
# Override the per-shift RNG seed for a consistent, deterministic data run.
#
# Recommended production value: 18606
#   VS1 L2 green FPY, VS1 L1 amber FPY, three at-risk lines (red borders),
#   all lines carrying 2-3 changeovers, output spread 56-95% of target.
#   Exercises every status colour and alert state in the UI.
#
# Omit to use shift defaults (day=1001, night=3003).
# Set in Vercel: Project > Settings > Environment Variables > DEMO_SEED
DEMO_SEED=18606

# PIN gate for /admin page (auth not yet enforced in code)
AUTH_PIN=bak2026
